        "phase": 2,
        "risk": "检索延迟超过 100ms 目标",
        "mitigation": "预量化索引、缓存热点查询、异步处理"
      },
      {
        "phase": 2,
        "risk": "时序数据写入吞吐不足",
        "mitigation": "使用 TimescaleDB 批量插入，调整压缩策略"
      },
      {
        "phase": 2,
        "risk": "知识图谱构建复杂度高",
        "mitigation": "先实现基础 CRUD，迭代添加关联挖掘功能"
      },
      {
        "phase": 3,
        "risk": "Kimi API 调用成本高、延迟大",
        "mitigation": "本地缓存常见问题，使用流式输出，设置超时重试"
      },
      {
        "phase": 3,
        "risk": "Kimi API 配额限制",
        "mitigation": "配置备用模型（如通义千问），实现降级策略"
      },
      {
        "phase": 4,
        "risk": "K8s 部署配置复杂",
        "mitigation": "使用 Helm Charts 模板化，逐步完善"
      }
    ],
    "milestones": [
      {
        "milestone": "M1: 基础平台可用",
        "phase": 1,
        "criteria": "采集接口接收数据，数据入湖和入时序库（TimescaleDB），基础认证可用，任务调度系统可用"
