{
    "rag_architecture": {
      "name": "教育平台RAG检索增强生成架构",
      "version": "1.0.0",
      "project": "可嵌入式跨课程AI_Agent通用架构平台",
      "overall_flow": "用户查询 → 查询处理 → 多路检索 → 融合重排 → 生成回答 → 反馈学习",
      "layers": [
        {
          "layer_name": "离线索引层",
          "layer_code": "OFFLINE",
          "description": "负责课程资料的离线处理、分块、向量化和索引构建",
          "components": [
            {
              "name": "原始数据源",
              "sources": [
                {"type": "教材文档", "format": "PDF/Markdown", "storage": "MinIO/edu-courseware"},
                {"type": "课程资料", "format": "HTML/Text", "storage": "PostgreSQL"},
                {"type": "历史问答", "format": "JSON", "storage": "PostgreSQL/faq_logs"},
                {"type": "知识图谱", "format": "Cypher", "storage": "Neo4j"},
                {"type": "作业样本", "format": "Text/Code", "storage": "MinIO/edu-homework"}
              ]
            },
            {
              "name": "智能分块引擎",
              "code": "CHUNK-ENGINE",
              "service": "KNOWLEDGE-SEARCH-OFFLINE",
              "tech_stack": {
                "primary": "LangChain Text Splitter",
                "version": "0.1.0",
                "deployment": "Celery定时任务"
              },
              "chunk_strategies": [
                {
                  "content_type": "教材",
                  "chunk_size": 1000,
                  "overlap": 200,
                  "separators": ["\n\n", "\n", "。", "；", "，"]
                },
                {
                  "content_type": "代码示例",
                  "chunk_size": 500,
                  "overlap": 50,
                  "separators": ["\n\n", "\n", "def", "class", "function"]
                },
                {
                  "content_type": "公式",
                  "chunk_size": 200,
                  "overlap": 20,
                  "separators": ["$$", "$", "\\[", "\\]"]
                },
                {
                  "content_type": "对话历史",
                  "chunk_size": 300,
                  "overlap": 30,
                  "separators": ["\n\n", "\n", "用户：", "助手："]
                }
              ],
              "scheduled_jobs": [
                {"name": "daily_full_index", "cron": "0 2 * * *", "type": "全量索引"},
                {"name": "incremental_update", "cron": "*/30 * * * *", "type": "增量更新"}
              ]
            },
            {
              "name": "向量化嵌入服务",
              "code": "EMBEDDING-SERVICE",
              "service": "KNOWLEDGE-SEARCH-OFFLINE",
              "tech_stack": {
                "primary": "sentence-transformers",
                "model": "all-MiniLM-L6-v2",
                "dimension": 384,
                "batch_size": 64,
                "gpu_acceleration": true,
                "quantization": "float16"
              },
              "embedding_cache": {
                "type": "Redis",
                "ttl": 86400,
                "max_size": 100000
              }
            },
            {
              "name": "FAISS索引构建",
              "code": "FAISS-INDEXER",
              "service": "KNOWLEDGE-SEARCH-OFFLINE",
              "tech_stack": {
                "primary": "FAISS",
                "version": "1.7.4",
                "index_type": "IVF4096,PQ16",
                "metric": "IP",
                "training_ratio": 0.1
              },
              "index_config": {
                "ivf": {"nlist": 4096, "nprobe": 32},
                "pq": {"m": 16, "nbits": 8},
                "compression": "Product Quantization"
              },
              "storage": {
                "primary": "内存索引",
                "backup": "MinIO/faiss-indexes",
                "versioning": true
              }
            },
            {
              "name": "Elasticsearch索引",
              "code": "ES-INDEXER",
              "service": "KNOWLEDGE-SEARCH-OFFLINE",
              "tech_stack": {
                "primary": "Elasticsearch 8.11",
                "analyzer": "ik_smart",
                "shards": 3,
                "replicas": 1
              },
              "mappings": {
                "properties": {
                  "title": {"type": "text", "analyzer": "ik_smart"},
                  "content": {"type": "text", "analyzer": "ik_smart"},
                  "course_id": {"type": "keyword"},
                  "knowledge_points": {"type": "keyword"},
                  "content_type": {"type": "keyword"},
                  "created_at": {"type": "date"},
                  "embedding_id": {"type": "keyword"}
                }
              }
            }
          ]
        },
        {
          "layer_name": "知识图谱层",
          "layer_code": "GRAPH",
          "description": "存储知识点关联关系，支持图遍历查询",
          "components": [
            {
              "name": "知识图谱存储",
              "code": "GRAPH-STORE",
              "service": "KNOWLEDGE-GRAPH",
              "tech_stack": {
                "primary": "Neo4j 5.14",
                "deployment": "因果集群（3核心服务器）",
                "driver": "neo4j-python-driver 5.14"
              },
              "node_labels": [
                "KnowledgePoint",
                "Course",
                "Example",
                "Exercise",
                "Student"
              ],
              "relationship_types": [
                "PREREQUISITE",
                "RELATED_TO",
                "BELONGS_TO",
                "HAS_EXAMPLE",
                "HAS_EXERCISE",
                "MASTERS"
              ],
              "schema": {
                "KnowledgePoint": {
                  "properties": ["id", "name", "category", "difficulty", "importance", "description"],
                  "indexes": ["id", "name"]
                },
                "Course": {
                  "properties": ["id", "name", "department", "level"],
                  "indexes": ["id"]
                }
              }
            },
            {
              "name": "Cypher查询引擎",
              "code": "CYPHER-ENGINE",
              "service": "KNOWLEDGE-GRAPH",
              "predefined_queries": [
                {
                  "name": "find_prerequisites",
                  "cypher": "MATCH (k:KnowledgePoint {name: $kp_name})-[:PREREQUISITE*1..3]->(prereq) RETURN prereq"
                },
                {
                  "name": "find_related",
                  "cypher": "MATCH (k:KnowledgePoint {name: $kp_name})-[:RELATED_TO]-(related) RETURN related"
                },
                {
                  "name": "find_path",
                  "cypher": "MATCH path = shortestPath((k1:KnowledgePoint {name: $from})-[*..5]-(k2:KnowledgePoint {name: $to})) RETURN path"
                },
                {
                  "name": "get_course_knowledge",
                  "cypher": "MATCH (c:Course {id: $course_id})-[:CONTAINS]->(k:KnowledgePoint) RETURN k"
                }
              ]
            }
          ]
        },
        {
          "layer_name": "在线检索层",
          "layer_code": "ONLINE",
          "description": "处理实时用户查询，执行多路检索",
          "components": [
            {
              "name": "查询处理服务",
              "code": "QUERY-PROCESSOR",
              "service": "KNOWLEDGE-SEARCH-ONLINE",
              "tech_stack": {
                "primary": "FastAPI",
                "protocols": ["HTTP/REST", "gRPC", "WebSocket"]
              },
              "api_endpoints": [
                {"path": "/api/v1/search", "method": "POST", "description": "通用检索"},
                {"path": "/api/v1/search/semantic", "method": "POST", "description": "语义检索"},
                {"path": "/api/v1/search/keyword", "method": "POST", "description": "关键词检索"},
                {"path": "/api/v1/search/graph", "method": "POST", "description": "图谱检索"},
                {"path": "/api/v1/search/rewrite", "method": "POST", "description": "查询改写"}
              ]
            },
            {
              "name": "查询改写服务",
              "code": "QUERY-REWRITE",
              "service": "KNOWLEDGE-SEARCH-ONLINE",
              "tech_stack": {
                "primary": "Kimi API",
                "model": "moonshot-v1-128k",
                "temperature": 0.3,
                "max_tokens": 200
              },
              "prompt_template": "请将以下学生问题扩展为更详细的搜索查询，包含同义词和相关概念。原始问题：{query}，课程上下文：{course_context}，返回3个扩展查询，每行一个。",
              "cache": {
                "type": "Redis",
                "ttl": 3600,
                "max_size": 10000
              }
            },
            {
              "name": "路由与意图识别",
              "code": "ROUTER",
              "service": "KNOWLEDGE-SEARCH-ONLINE",
              "tech_stack": {
                "primary": "Python分类器",
                "model": "LogisticRegression",
                "features": ["query_length", "keyword_presence", "question_type"]
              },
              "routing_rules": [
                {"intent": "概念解释", "channels": ["semantic", "graph"]},
                {"intent": "关系查询", "channels": ["graph"]},
                {"intent": "题目查找", "channels": ["keyword", "semantic"]},
                {"intent": "代码问题", "channels": ["semantic", "keyword"]},
                {"intent": "历史回顾", "channels": ["keyword"]}
              ],
              "default_channels": ["semantic", "keyword"]
            },
            {
              "name": "语义检索执行器",
              "code": "SEMANTIC-SEARCH",
              "service": "KNOWLEDGE-SEARCH-ONLINE",
              "tech_stack": {
                "primary": "FAISS",
                "index_type": "IVF4096,PQ16",
                "nprobe": 32,
                "top_k": 50
              },
              "query_embedding": {
                "model": "all-MiniLM-L6-v2",
                "batch": true
              },
              "performance": {
                "latency_p95": "30ms",
                "qps": 1000
              }
            },
            {
              "name": "关键词检索执行器",
              "code": "KEYWORD-SEARCH",
              "service": "KNOWLEDGE-SEARCH-ONLINE",
              "tech_stack": {
                "primary": "Elasticsearch 8.11",
                "query_type": "BM25",
                "top_k": 50
              },
              "query_template": {
                "bool": {
                  "should": [
                    {"match": {"title": {"query": "{query}", "boost": 2}}},
                    {"match": {"content": {"query": "{query}", "boost": 1}}}
                  ],
                  "filter": [
                    {"term": {"course_id": "{course_id}"}}
                  ]
                }
              }
            },
            {
              "name": "图谱检索执行器",
              "code": "GRAPH-SEARCH",
              "service": "KNOWLEDGE-SEARCH-ONLINE",
              "tech_stack": {
                "primary": "Neo4j",
                "driver": "neo4j-python-driver"
              },
              "query_templates": {
                "entity_search": "MATCH (k:KnowledgePoint) WHERE k.name CONTAINS $keyword RETURN k",
                "relation_search": "MATCH (k:KnowledgePoint {name: $entity})-[r]-(related) RETURN related, type(r)"
              }
            },
            {
              "name": "多路结果融合",
              "code": "FUSION",
              "service": "KNOWLEDGE-SEARCH-ONLINE",
              "strategy": "加权融合",
              "weights": {
                "semantic": 0.4,
                "keyword": 0.3,
                "graph": 0.3
              },
              "normalization": "min-max",
              "deduplication": {
                "method": "语义相似度",
                "threshold": 0.85
              }
            }
          ]
        },
        {
          "layer_name": "重排序层",
          "layer_code": "RERANK",
          "description": "对检索结果进行精细化重排序",
          "components": [
            {
              "name": "交叉编码器服务",
              "code": "CROSS-ENCODER",
              "service": "KNOWLEDGE-SEARCH-ONLINE",
              "tech_stack": {
                "primary": "交叉编码器",
                "model": "cross-encoder/ms-marco-MiniLM-L-6-v2",
                "deployment": "TorchServe",
                "batch_size": 32,
                "gpu_acceleration": true
              },
              "api_endpoint": "/api/v1/rerank",
              "performance": {
                "latency_p95": "40ms",
                "throughput": "500 requests/s"
              }
            },
            {
              "name": "上下文修剪",
              "code": "CONTEXT-TRIMMER",
              "service": "KNOWLEDGE-SEARCH-ONLINE",
              "strategy": "token预算优化",
              "max_tokens": 3000,
              "compression_methods": [
                {"name": "重要性排序", "field": "rerank_score"},
                {"name": "语义去重", "threshold": 0.9},
                {"name": "多样性保证", "mmr_lambda": 0.5}
              ]
            }
          ]
        },
        {
          "layer_name": "生成层",
          "layer_code": "GENERATION",
          "description": "基于检索结果生成最终回答",
          "components": [
            {
              "name": "LLM生成服务",
              "code": "LLM-GENERATION",
              "service": "INT-CHAT",
              "tech_stack": {
                "primary": "Kimi API",
                "model": "moonshot-v1-128k",
                "temperature": 0.7,
                "max_tokens": 2000,
                "streaming": true
              },
              "prompt_templates": {
                "qa": {
                  "system": "你是一个智能教学助手，基于课程知识图谱和学生历史学习数据，回答学生问题。",
                  "user": "参考资料：{context}\n\n学生问题：{query}\n课程：{course_name}\n学生历史薄弱点：{weak_points}\n\n请用中文回答，简洁准确，鼓励学生。"
                },
                "grading": {
                  "system": "你是一个作业批改助手，基于参考答案给出详细的批改意见。",
                  "user": "参考答案：{reference}\n\n学生作业：{submission}\n错误分析：{error_analysis}\n\n请指出错误位置、解释错误原因、给出改进建议。"
                },
                "exercise": {
                  "system": "你是一个练习生成助手，基于学生薄弱点生成个性化练习题。",
                  "user": "薄弱知识点：{weak_points}\n难度：{difficulty}\n题型：{question_types}\n\n请生成练习题，包含题目、选项（如果是选择题）、答案和详细解析。"
                }
              },
              "context_window": {
                "max_context_length": 10000,
                "truncation_strategy": "保留最新"
              }
            },
            {
              "name": "流式输出",
              "code": "STREAMING",
              "service": "INT-CHAT",
              "websocket_endpoint": "/ws/chat/{session_id}",
              "chunk_size": 50,
              "heartbeat_interval": 10
            }
          ]
        },
        {
          "layer_name": "反馈与学习层",
          "layer_code": "FEEDBACK",
          "description": "收集用户反馈，持续优化检索和生成效果",
          "components": [
            {
              "name": "反馈收集服务",
              "code": "FEEDBACK-COLLECTOR",
              "service": "DATA-COLLECT",
              "storage": "PostgreSQL",
              "feedback_types": [
                {"type": "点赞/点踩", "fields": ["answer_id", "rating"]},
                {"type": "纠错", "fields": ["answer_id", "correction", "reason"]},
                {"type": "补充资料", "fields": ["answer_id", "additional_info"]}
              ]
            },
            {
              "name": "在线学习",
              "code": "ONLINE-LEARNING",
              "service": "INT-EVALUATE",
              "update_frequency": "每日",
              "learning_algorithms": [
                {"name": "权重调整", "target": "fusion_weights", "method": "贝叶斯优化"},
                {"name": "查询改写优化", "target": "rewrite_prompt", "method": "强化学习"},
                {"name": "重排序模型微调", "target": "cross-encoder", "method": "增量训练"}
              ]
            }
          ]
        }
      ],
      "data_flow": {
        "离线流程": "原始文档 → 智能分块 → 向量化嵌入 → FAISS索引 → MinIO备份",
        "在线流程": "用户查询 → 查询改写 → 意图识别 → 多路检索(FAISS+ES+Neo4j) → 结果融合 → 重排序 → 上下文压缩 → LLM生成 → 流式返回"
      },
      "performance_targets": {
        "检索延迟": {
          "p50": "50ms",
          "p95": "100ms",
          "p99": "200ms"
        },
        "重排序延迟": {
          "p50": "20ms",
          "p95": "40ms",
          "p99": "80ms"
        },
        "生成延迟": {
          "first_token": "300ms",
          "total_p95": "3s"
        },
        "端到端延迟": {
          "p95": "500ms",
          "p99": "1s"
        },
        "吞吐量": "100 QPS",
        "准确率": {
          "检索召回率@10": "0.85",
          "NDCG@10": "0.75",
          "回答准确率": "0.95"
        }
      },
      "service_mapping": {
        "KNOWLEDGE-SEARCH-OFFLINE": ["CHUNK-ENGINE", "EMBEDDING-SERVICE", "FAISS-INDEXER", "ES-INDEXER"],
        "KNOWLEDGE-GRAPH": ["GRAPH-STORE", "CYPHER-ENGINE"],
        "KNOWLEDGE-SEARCH-ONLINE": ["QUERY-PROCESSOR", "QUERY-REWRITE", "ROUTER", "SEMANTIC-SEARCH", "KEYWORD-SEARCH", "GRAPH-SEARCH", "FUSION", "CROSS-ENCODER", "CONTEXT-TRIMMER"],
        "INT-CHAT": ["LLM-GENERATION", "STREAMING"],
        "DATA-COLLECT": ["FEEDBACK-COLLECTOR"],
        "INT-EVALUATE": ["ONLINE-LEARNING"]
      },
      "kimi_integration": {
        "usage_points": [
          {"service": "QUERY-REWRITE", "purpose": "查询扩展", "avg_tokens": 150},
          {"service": "LLM-GENERATION", "purpose": "回答生成", "avg_tokens": 800},
          {"service": "GRADING", "purpose": "批注生成", "avg_tokens": 600},
          {"service": "EXERCISE", "purpose": "练习生成", "avg_tokens": 1000}
        ],
        "cost_control": {
          "cache_enabled": true,
          "cache_ttl": 3600,
          "batch_processing": true,
          "rate_limit": "1000 RPM",
          "fallback_strategy": "本地模板"
        },
        "prompt_engineering": {
          "qa_system_prompt": "你是一个智能教学助手，基于课程知识图谱和学生历史学习数据，回答学生问题。",
          "grading_system_prompt": "你是一个作业批改助手，基于参考答案给出详细的批改意见。",
          "exercise_system_prompt": "你是一个练习生成助手，基于学生薄弱点生成个性化练习题。"
        }
      },
      "cache_strategy": {
        "level1": {
          "type": "Redis",
          "ttl": 3600,
          "max_size": 10000,
          "cache_keys": ["embedding", "rewrite", "search_results"]
        },
        "level2": {
          "type": "本地内存",
          "ttl": 300,
          "max_size": 1000,
          "cache_keys": ["frequent_queries"]
        }
      },
      "monitoring": {
        "metrics": [
          {"name": "检索延迟", "source": "prometheus"},
          {"name": "缓存命中率", "source": "redis"},
          {"name": "Kimi API消耗", "source": "custom_counter"},
          {"name": "检索准确率", "source": "feedback_analysis"}
        ],
        "alerts": [
          {"condition": "检索延迟 > 200ms", "severity": "warning"},
          {"condition": "Kimi API错误率 > 5%", "severity": "critical"},
          {"condition": "缓存命中率 < 50%", "severity": "info"}
        ]
      }
    }
  }