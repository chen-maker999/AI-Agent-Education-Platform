# Application Environment Variables
# Copy this file to .env and fill in your actual values

# App
APP_NAME=AI-Agent-Education-Platform
APP_VERSION=1.0.0
DEBUG=True
API_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=edu_platform

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Neo4j
NEO4J_HOST=localhost
NEO4J_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Kimi API (Moonshot) - Get from https://platform.moonshot.cn/
KIMI_API_KEY=sk-6fs9zZSBTDqkRa9tPtZ39hAj3TRWFPy1exIA7aCCEYovmpzg
KIMI_API_ENDPOINT=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k
KIMI_TIMEOUT=30

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# CORS
CORS_ORIGINS=["*"]

# Consul
CONSUL_HOST=localhost
CONSUL_PORT=8500
